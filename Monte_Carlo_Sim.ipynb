import random
import math


s = 1000
d = 252
starting_price = 100
final_prices = []
annual_vol = 0.28
daily_vol = annual_vol / math.sqrt(252)

for i in range(1, s + 1):
    price = starting_price

    for day in range(1, d + 1):
        if random.random() < 0.02:
            #Crash
            change = random.gauss(-0.05, daily_vol * 5)
        else:
            #Normal
            change = random.uniform(-0.02, 0.02)

        price *= (1 + change)

        if price <= 0:
            price = 0
            break


    final_prices.append(price)

average_final_price = sum(final_prices) / len(final_prices)

print("="*30)
print(f"SIMULATION COMPLETE: {s} runs")
print("="*30)
print(f"Average Final Price: ${average_final_price:.2f}")
print("-"*30)
print(f"Highest Possible:    ${max(final_prices):.2f}")
print("-"*30)
print(f"Lowest Possible:     ${min(final_prices):.2f}")
print("="*30)
